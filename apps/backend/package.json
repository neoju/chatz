{
  "name": "backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json}\"",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "fastify": "^5.8.5"
  },
  "devDependencies": {
    "@chatz/eslint-config": "workspace:*",
    "@chatz/typescript-config": "workspace:*",
    "@types/node": "^22.10.0",
    "eslint": "^9.18.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
