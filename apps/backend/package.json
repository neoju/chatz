{
  "name": "backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch --tsconfig ./tsconfig.json src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --import tsconfig-paths/register dist/server.js",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json}\"",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@chatz/dto": "workspace:*",
    "@chatz/shared": "workspace:*",
    "@fastify/env": "^6.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "bcrypt": "^6.0.0",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.1"
  },
  "devDependencies": {
    "@chatz/eslint-config": "workspace:*",
    "@chatz/typescript-config": "workspace:*",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.0",
    "eslint": "^9.18.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
