{
  "name": "backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch --tsconfig ./tsconfig.json src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --import tsconfig-paths/register dist/server.js",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json}\"",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:seed": "tsx --tsconfig ./tsconfig.json src/scripts/seed.ts"
  },
  "dependencies": {
    "@chatz/dto": "workspace:*",
    "@chatz/email-template": "workspace:*",
    "@chatz/shared": "workspace:*",
    "@fastify/cors": "^11.2.0",
    "@fastify/env": "^6.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@react-email/render": "^1.4.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.76.5",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.1",
    "nodemailer": "^8.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@chatz/eslint-config": "workspace:*",
    "@chatz/typescript-config": "workspace:*",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^8.0.0",
    "eslint": "^9.18.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.1.1"
  }
}
