{
  "name": "frontend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --host 0.0.0.0 --port 5173",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,js,svelte,json,html,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,svelte,json,html,css}\"",
    "check-types": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
  },
  "devDependencies": {
    "@chatz/eslint-config": "workspace:*",
    "@chatz/typescript-config": "workspace:*",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.59.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.18.0",
    "svelte": "^5.55.5",
    "svelte-check": "^4.0.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.2"
  }
}
