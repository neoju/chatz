{
  "name": "@chatz/email-template",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "email dev --port 3001",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,js,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json}\"",
    "check-types": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@react-email/components": "^0.0.36",
    "@react-email/render": "^1.0.5",
    "@react-email/tailwind": "^2.0.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-email": "^4.0.7"
  },
  "devDependencies": {
    "@chatz/eslint-config": "workspace:*",
    "@chatz/typescript-config": "workspace:*",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
