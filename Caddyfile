{$CADDY_SITE_ADDRESS::80} {
	encode gzip zstd

	handle /ws/* {
		reverse_proxy http://backend:3000 {
			transport http {
				read_timeout 24h
				write_timeout 24h
			}
		}
	}

	handle /api/* {
		reverse_proxy http://backend:3000
	}

	handle {
		root * /srv/frontend
		try_files {path} /index.html
		file_server
	}
}
